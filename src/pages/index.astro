---
import Layout from '../layouts/Layout.astro';
import appScriptUrl from '../scripts/app.js?url';
---

<Layout
  title="Bitrate Compare — Video File Size Calculator"
  description="Compare video bitrate profiles, file sizes, storage yield, and upload times in a fast static calculator built for production planning."
>
  <div class="flex min-h-dvh flex-col">
    <header class="sticky top-0 z-50 border-b border-white/10 bg-zinc-950/90 backdrop-blur light:border-zinc-200 light:bg-zinc-50/90">
      <div class="mx-auto flex min-h-13 w-full max-w-6xl items-center justify-between px-4 py-2.5 sm:px-5">
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex size-7 shrink-0 items-center justify-center rounded-[0.45rem] bg-indigo-500 text-white shadow-lg shadow-indigo-500/20">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="min-w-0">
            <span class="block truncate font-display text-sm font-bold tracking-[-0.01em] text-zinc-100 light:text-zinc-900">Bitrate Compare</span>
            <p class="mt-0.5 hidden text-[11px] text-zinc-400 sm:block light:text-zinc-500">Plan storage, transfer time, and media cost before you roll cameras.</p>
          </div>
        </div>
        <div class="flex items-center gap-1.5">
          <button
            id="themeToggle"
            class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl border border-white/10 text-zinc-400 transition hover:border-white/20 hover:bg-white/5 hover:text-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:border-zinc-200 light:text-zinc-500 light:hover:border-zinc-300 light:hover:bg-zinc-100 light:hover:text-zinc-900"
            aria-label="Toggle theme"
            type="button"
          >
            <svg id="iconSun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg id="iconMoon" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>
          <button
            id="shareConfig"
            class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl border border-white/10 text-zinc-400 transition hover:border-white/20 hover:bg-white/5 hover:text-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:border-zinc-200 light:text-zinc-500 light:hover:border-zinc-300 light:hover:bg-zinc-100 light:hover:text-zinc-900"
            aria-label="Share configuration"
            type="button"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <main id="main-content" class="mx-auto flex w-full max-w-6xl flex-1 flex-col gap-4 px-4 py-4 pb-10 sm:px-5" tabindex="-1">
      <section class="overflow-hidden rounded-[1.125rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(99,102,241,0.18),transparent_34%),linear-gradient(180deg,rgba(31,31,35,0.95),rgba(17,17,19,1))] p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-[radial-gradient(circle_at_top_left,rgba(79,70,229,0.12),transparent_34%),linear-gradient(180deg,#ffffff,#f4f4f5)]">
        <div class="max-w-xl">
          <span class="inline-flex min-h-7 items-center rounded-full bg-indigo-500/12 px-3 text-[11px] font-bold uppercase tracking-[0.08em] text-indigo-300 light:bg-indigo-500/10 light:text-indigo-600">Production planning</span>
          <h1 class="mt-2.5 max-w-[11ch] font-display text-[clamp(1.7rem,3.2vw,2.2rem)] leading-none font-semibold tracking-[-0.04em] text-white light:text-zinc-950">Compare recording profiles fast.</h1>
          <p class="mt-2.5 max-w-[50ch] text-sm leading-6 text-zinc-400 light:text-zinc-600">Set a duration, add camera presets or manual bitrates, and compare file size, storage yield, and upload time.</p>
        </div>
        <div class="mt-4 grid gap-2 md:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-white/4 p-3 light:border-zinc-200 light:bg-zinc-100">
            <span class="inline-flex size-6 items-center justify-center rounded-full bg-zinc-800 text-xs font-bold text-zinc-100 light:bg-white light:text-zinc-900">1</span>
            <p class="mt-2 text-xs text-zinc-400 light:text-zinc-600">Set total record time.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/4 p-3 light:border-zinc-200 light:bg-zinc-100">
            <span class="inline-flex size-6 items-center justify-center rounded-full bg-zinc-800 text-xs font-bold text-zinc-100 light:bg-white light:text-zinc-900">2</span>
            <p class="mt-2 text-xs text-zinc-400 light:text-zinc-600">Add one or more profiles.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/4 p-3 light:border-zinc-200 light:bg-zinc-100">
            <span class="inline-flex size-6 items-center justify-center rounded-full bg-zinc-800 text-xs font-bold text-zinc-100 light:bg-white light:text-zinc-900">3</span>
            <p class="mt-2 text-xs text-zinc-400 light:text-zinc-600">Use the first row as your baseline comparison.</p>
          </div>
        </div>
      </section>

      <section class="rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-3 flex items-start justify-between gap-3">
          <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">Shoot Duration</span>
          <span id="totalDuration" class="text-sm font-bold tabular-nums text-indigo-300 light:text-indigo-600">0s</span>
        </div>
        <p class="mb-3.5 text-xs leading-5 text-zinc-400 light:text-zinc-600">Set the total record time for a single card, interview, or shooting day.</p>
        <div class="grid grid-cols-3 gap-2.5">
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="hours">Hours</label>
            <input id="hours" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-center text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="0" min="0" placeholder="0" inputmode="numeric" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="minutes">Minutes</label>
            <input id="minutes" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-center text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="10" min="0" placeholder="0" inputmode="numeric" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="seconds">Seconds</label>
            <input id="seconds" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-center text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="0" min="0" placeholder="0" inputmode="numeric" />
          </div>
        </div>
        <p id="durationHint" class="mt-1.5 text-xs leading-5 text-zinc-500 light:text-zinc-500">Need a quick estimate? Start with the planned runtime of the scene, interview, or full shooting block.</p>
      </section>

      <section class="rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-2 flex items-start justify-between gap-3">
          <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">Recording Profiles</span>
          <span class="max-w-28 text-right text-xs font-semibold text-zinc-500 light:text-zinc-500 sm:max-w-none">Add presets or manual targets</span>
        </div>
        <p class="mb-3.5 text-xs leading-5 text-zinc-400 light:text-zinc-600">Use real camera presets when possible. Manual mode is useful for proxies, mezzanine exports, or delivery targets.</p>
        <div class="mb-3 flex rounded-lg bg-zinc-800 p-[3px] light:bg-zinc-100" role="tablist" aria-label="Add profile mode">
          <button id="modeCameraBtn" class="flex-1 rounded-md px-3 py-3 text-xs font-semibold text-zinc-100 shadow-sm transition aria-selected:bg-zinc-900 aria-selected:text-zinc-100 aria-selected:shadow-[0_1px_2px_rgba(0,0,0,0.2)] light:text-zinc-500 light:aria-selected:bg-white light:aria-selected:text-zinc-900" type="button" role="tab" aria-selected="true" aria-controls="cameraMode">Camera Preset</button>
          <button id="modeManualBtn" class="flex-1 rounded-md px-3 py-3 text-xs font-semibold text-zinc-500 transition aria-selected:bg-zinc-900 aria-selected:text-zinc-100 aria-selected:shadow-[0_1px_2px_rgba(0,0,0,0.2)] light:text-zinc-500 light:aria-selected:bg-white light:aria-selected:text-zinc-900" type="button" role="tab" aria-selected="false" aria-controls="manualMode">Manual</button>
        </div>

        <div id="cameraMode" class="space-y-2.5" role="tabpanel" aria-labelledby="modeCameraBtn">
          <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="cameraSelect">Camera</label>
          <div class="relative" data-select-wrap>
            <select id="cameraSelect" class="w-full appearance-none rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 pr-10 text-sm font-medium text-zinc-100 outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900" name="cameraSelect" autocomplete="off" aria-describedby="cameraPresetHint">
              <option value="">Choose a camera...</option>
            </select>
            <svg class="pointer-events-none absolute top-1/2 right-3 size-4 -translate-y-1/2 text-zinc-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
          <p id="cameraPresetHint" class="mt-1.5 text-xs leading-5 text-zinc-500 light:text-zinc-500">Pick a camera first, then choose its recording preset.</p>
          <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="codecSelect">Codec / Bitrate</label>
          <div class="relative hidden" data-select-wrap>
            <select id="codecSelect" class="w-full appearance-none rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 pr-10 text-sm font-medium text-zinc-100 outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900" name="codecSelect" autocomplete="off">
              <option value="">Choose codec / bitrate...</option>
            </select>
            <svg class="pointer-events-none absolute top-1/2 right-3 size-4 -translate-y-1/2 text-zinc-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
          <button id="addCameraProfile" class="hidden w-full items-center justify-center gap-1.5 rounded-xl bg-indigo-500 px-4 py-3 text-sm font-semibold text-white transition hover:opacity-90 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add to Comparison
          </button>
        </div>

        <div id="manualMode" class="hidden space-y-2.5" role="tabpanel" aria-labelledby="modeManualBtn">
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="manualName">Profile Name</label>
            <input id="manualName" name="manualName" type="text" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" placeholder="Example: ProRes 422 HQ" autocomplete="off" aria-describedby="manualProfileHelp" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="manualBitrate">Bitrate (Mbps)</label>
            <div class="grid gap-2.5 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
              <input id="manualBitrate" name="manualBitrate" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="100" min="1" step="0.1" inputmode="decimal" aria-describedby="manualProfileHelp manualValidation" />
              <button id="addManualProfile" class="inline-flex items-center justify-center gap-1.5 rounded-xl bg-indigo-500 px-4 py-3 text-sm font-semibold text-white transition hover:opacity-90 active:scale-[0.98] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add Profile
              </button>
            </div>
          </div>
          <div class="flex flex-wrap gap-2" aria-label="Quick bitrate presets">
            <button class="min-h-10 rounded-full border border-white/10 bg-zinc-800 px-3.5 text-xs font-semibold text-zinc-400 transition hover:border-indigo-400/50 hover:bg-indigo-500/10 hover:text-zinc-100 aria-pressed:border-indigo-400/60 aria-pressed:bg-indigo-500/15 aria-pressed:text-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-600 light:hover:bg-indigo-50 light:hover:text-indigo-700 light:aria-pressed:border-indigo-300 light:aria-pressed:bg-indigo-50 light:aria-pressed:text-indigo-700" type="button" data-bitrate-chip="45" aria-pressed="true">45 Mbps</button>
            <button class="min-h-10 rounded-full border border-white/10 bg-zinc-800 px-3.5 text-xs font-semibold text-zinc-400 transition hover:border-indigo-400/50 hover:bg-indigo-500/10 hover:text-zinc-100 aria-pressed:border-indigo-400/60 aria-pressed:bg-indigo-500/15 aria-pressed:text-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-600 light:hover:bg-indigo-50 light:hover:text-indigo-700 light:aria-pressed:border-indigo-300 light:aria-pressed:bg-indigo-50 light:aria-pressed:text-indigo-700" type="button" data-bitrate-chip="50" aria-pressed="false">50 Mbps</button>
            <button class="min-h-10 rounded-full border border-white/10 bg-zinc-800 px-3.5 text-xs font-semibold text-zinc-400 transition hover:border-indigo-400/50 hover:bg-indigo-500/10 hover:text-zinc-100 aria-pressed:border-indigo-400/60 aria-pressed:bg-indigo-500/15 aria-pressed:text-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-600 light:hover:bg-indigo-50 light:hover:text-indigo-700 light:aria-pressed:border-indigo-300 light:aria-pressed:bg-indigo-50 light:aria-pressed:text-indigo-700" type="button" data-bitrate-chip="100" aria-pressed="false">100 Mbps</button>
          </div>
          <p id="manualProfileHelp" class="mt-1.5 text-xs leading-5 text-zinc-500 light:text-zinc-500">Leave the name blank to auto-label it. Rows stay editable after you add them, so you can tune names and bitrates in place.</p>
          <p id="manualValidation" class="mt-1.5 min-h-[18px] text-xs leading-5 text-zinc-500 data-[state=warning]:text-amber-400 data-[state=error]:text-rose-400 data-[state=success]:text-emerald-400 light:text-zinc-500 light:data-[state=warning]:text-amber-600 light:data-[state=error]:text-rose-600 light:data-[state=success]:text-emerald-600" aria-live="polite"></p>
        </div>
      </section>

      <section id="comparisonSection" class="hidden rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-3 flex items-start justify-between gap-3">
          <div>
            <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">File Size Comparison <span id="profileCount" class="text-indigo-300 light:text-indigo-600">0</span></span>
            <p id="comparisonHint" class="mt-1 text-xs leading-5 text-zinc-500 light:text-zinc-500">The first row acts as the baseline for size delta.</p>
          </div>
          <button id="clearAll" class="rounded-md px-2 py-1 text-[11px] font-medium text-zinc-500 transition hover:bg-rose-500/8 hover:text-rose-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:hover:bg-rose-50 light:hover:text-rose-600" type="button">Clear all</button>
        </div>
        <div class="-mx-4 mt-2 overflow-x-auto px-4 [scrollbar-width:thin]">
          <table class="w-full min-w-[720px] border-collapse text-left text-xs">
            <caption class="sr-only">Recorded profile comparison table</caption>
            <thead>
              <tr>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Profile</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Bitrate</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Est. Size</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Delta vs 1st</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Media Cost</th>
                <th class="pr-0 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Actions</th>
              </tr>
            </thead>
            <tbody id="profilesContainer">
              <tr class="sr-only">
                <td colspan="6">No profiles added yet.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p id="profilesEmpty" class="mt-3 rounded-2xl border border-dashed border-white/10 bg-zinc-800/70 p-3.5 text-xs leading-5 text-zinc-500 data-[state=warning]:text-amber-400 data-[state=error]:text-rose-400 data-[state=success]:text-emerald-400 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-500 light:data-[state=warning]:text-amber-600 light:data-[state=error]:text-rose-600 light:data-[state=success]:text-emerald-600">No profiles yet. Add a camera preset or manual bitrate to compare file size, upload time, and storage yield.</p>
      </section>

      <section id="chartSection" class="hidden rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-2 flex items-start justify-between gap-3">
          <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">Size Comparison</span>
          <span class="max-w-28 text-right text-xs font-semibold text-zinc-500 light:text-zinc-500 sm:max-w-none">Visual size spread</span>
        </div>
        <p class="mb-3.5 text-xs leading-5 text-zinc-400 light:text-zinc-600">Bars scale relative to the largest file size in your current comparison.</p>
        <div id="barChart" class="mt-2"></div>
      </section>

      <section class="rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-2 flex items-start justify-between gap-3">
          <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">Planning Assumptions</span>
          <span class="max-w-28 text-right text-xs font-semibold text-zinc-500 light:text-zinc-500 sm:max-w-none">Storage and transfer</span>
        </div>
        <p class="mb-3.5 text-xs leading-5 text-zinc-400 light:text-zinc-600">Adjust these assumptions to estimate media cost per profile and total recording time per drive.</p>
        <div class="grid gap-2.5 md:grid-cols-3">
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="availableStorage">Available Storage (GB)</label>
            <input id="availableStorage" name="availableStorage" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="500" min="0" step="1" inputmode="numeric" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="costPerTB">Media Cost ($/TB)</label>
            <input id="costPerTB" name="costPerTB" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="20" min="0" step="0.01" inputmode="decimal" />
          </div>
          <div>
            <label class="mb-1.5 block text-[11px] font-semibold text-zinc-400 light:text-zinc-600" for="customSpeed">Custom Upload Speed (Mbps)</label>
            <input id="customSpeed" name="customSpeed" type="number" class="w-full rounded-xl border border-white/10 bg-zinc-800 px-3 py-3 text-sm font-medium text-zinc-100 outline-none transition placeholder:text-zinc-500 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/20 aria-invalid:border-rose-400 aria-invalid:ring-2 aria-invalid:ring-rose-500/20 light:border-zinc-200 light:bg-zinc-100 light:text-zinc-900 light:placeholder:text-zinc-400" value="50" min="1" step="1" inputmode="numeric" />
          </div>
        </div>
        <p id="settingsStatus" class="mt-1.5 text-xs leading-5 text-zinc-500 light:text-zinc-500">Costs assume decimal TB and transfer speeds in megabits per second.</p>
      </section>

      <section id="uploadSection" class="hidden rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-2 flex items-start justify-between gap-3">
          <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">Upload Estimates</span>
          <span class="max-w-28 text-right text-xs font-semibold text-zinc-500 light:text-zinc-500 sm:max-w-none">Based on full file size</span>
        </div>
        <p class="mb-3.5 text-xs leading-5 text-zinc-400 light:text-zinc-600">Use this to spot whether dailies, proxies, or mezzanine files can move in your available window.</p>
        <div class="-mx-4 overflow-x-auto px-4 [scrollbar-width:thin]">
          <table class="w-full min-w-[720px] border-collapse text-left text-xs">
            <caption class="sr-only">Upload estimate table</caption>
            <thead>
              <tr>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Profile</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">Size</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">20M</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">100M</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">1G</th>
                <th class="pr-2 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col">10G</th>
                <th class="pr-0 pb-2 text-[10px] font-semibold uppercase tracking-[0.05em] text-zinc-500 light:text-zinc-500" scope="col" id="customSpeedHeader">50M</th>
              </tr>
            </thead>
            <tbody id="uploadTable">
              <tr class="sr-only">
                <td colspan="7">Add profiles to see upload estimates.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section id="yieldSection" class="hidden rounded-[1.125rem] border border-white/10 bg-zinc-900 p-4 shadow-[0_20px_40px_rgba(0,0,0,0.16)] light:border-zinc-200 light:bg-white">
        <div class="mb-3 flex items-start justify-between gap-3">
          <div>
            <span class="block text-[11px] font-bold uppercase tracking-[0.08em] text-zinc-400 light:text-zinc-500">Storage Yield</span>
            <p class="mt-1 text-xs leading-5 text-zinc-500 light:text-zinc-500">Estimated total record time each profile gets from the storage value above.</p>
          </div>
          <span class="text-xs font-semibold tabular-nums text-zinc-400 light:text-zinc-600" id="yieldStorageLabel">500 GB</span>
        </div>
        <div id="capacityResults" class="flex flex-col gap-1"></div>
      </section>
    </main>

    <footer class="px-4 py-4 text-center text-[10px] font-medium uppercase tracking-[0.06em] text-zinc-600 light:text-zinc-400">
      Bitrate Compare &bull; 2025
    </footer>

    <div id="toast" class="pointer-events-none fixed right-4 bottom-4 translate-y-16 rounded-2xl border border-white/10 bg-zinc-900 px-4 py-3 text-sm font-medium text-zinc-100 opacity-0 shadow-2xl transition duration-200 data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100 light:border-zinc-200 light:bg-white light:text-zinc-900" data-visible="false" aria-live="polite">Link copied to clipboard</div>
  </div>

  <script type="module" src={appScriptUrl}></script>
</Layout>
