---
import Layout from '../layouts/Layout.astro';
import appScriptUrl from '../scripts/app.js?url';
---

<Layout
  title="Bitrate Compare — Video File Size Calculator"
  description="Compare video bitrate profiles, file sizes, storage yield, and upload times in a fast static calculator built for production planning."
>
  <div class="app-shell">
    <header class="header-bar">
      <div class="header-inner">
        <div class="header-left">
          <div class="logo-mark">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <span class="header-title">Bitrate Compare</span>
            <p class="header-subtitle">Plan storage, transfer time, and media cost before you roll cameras.</p>
          </div>
        </div>
        <div class="header-right">
          <button id="themeToggle" class="btn-icon" aria-label="Toggle theme">
            <svg id="iconSun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="iconMoon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>
          <button id="shareConfig" class="btn-icon" aria-label="Share configuration">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <main id="main-content" class="main-content" tabindex="-1">
      <section class="hero-panel card">
        <div class="hero-copy">
          <span class="eyebrow">Production planning</span>
          <h1 class="hero-title">Compare recording profiles fast.</h1>
          <p class="hero-text">Set a duration, add camera presets or manual bitrates, and compare file size, storage yield, and upload time.</p>
        </div>
        <div class="hero-notes" aria-label="How it works">
          <div class="hero-note">
            <span class="hero-note-step">1</span>
            <p>Set total record time.</p>
          </div>
          <div class="hero-note">
            <span class="hero-note-step">2</span>
            <p>Add one or more profiles.</p>
          </div>
          <div class="hero-note">
            <span class="hero-note-step">3</span>
            <p>Use the first row as your baseline comparison.</p>
          </div>
        </div>
      </section>

      <!-- Duration -->
      <section class="card">
        <div class="section-header">
          <span class="section-label">Shoot Duration</span>
          <span id="totalDuration" class="duration-badge">0s</span>
        </div>
        <p class="helper-text section-intro">Set the total record time for a single card, interview, or shooting day.</p>
        <div class="duration-grid">
          <div>
            <label class="field-label" for="hours">Hours</label>
            <input id="hours" type="number" class="input-field input-center" value="0" min="0" placeholder="0" inputmode="numeric" />
          </div>
          <div>
            <label class="field-label" for="minutes">Minutes</label>
            <input id="minutes" type="number" class="input-field input-center" value="10" min="0" placeholder="0" inputmode="numeric" />
          </div>
          <div>
            <label class="field-label" for="seconds">Seconds</label>
            <input id="seconds" type="number" class="input-field input-center" value="0" min="0" placeholder="0" inputmode="numeric" />
          </div>
        </div>
        <p id="durationHint" class="helper-text">Need a quick estimate? Start with the planned runtime of the scene, interview, or full shooting block.</p>
      </section>

      <!-- Add Profile -->
      <section class="card">
        <div class="section-header section-header-tight">
          <span class="section-label">Recording Profiles</span>
          <span class="section-kicker">Add presets or manual targets</span>
        </div>
        <p class="helper-text section-intro">Use real camera presets when possible. Manual mode is useful for proxies, mezzanine exports, or delivery targets.</p>
        <div class="tab-group" role="tablist" aria-label="Add profile mode">
          <button id="modeCameraBtn" class="tab-btn active" type="button" role="tab" aria-selected="true" aria-controls="cameraMode">Camera Preset</button>
          <button id="modeManualBtn" class="tab-btn" type="button" role="tab" aria-selected="false" aria-controls="manualMode">Manual</button>
        </div>

        <div id="cameraMode" class="stack-sm" role="tabpanel" aria-labelledby="modeCameraBtn">
          <label class="field-label" for="cameraSelect">Camera</label>
          <select id="cameraSelect" class="select-field" name="cameraSelect" autocomplete="off" aria-describedby="cameraPresetHint">
            <option value="">Choose a camera...</option>
          </select>
          <p id="cameraPresetHint" class="helper-text">Pick a camera first, then choose its recording preset.</p>
          <label class="field-label" for="codecSelect">Codec / Bitrate</label>
          <select id="codecSelect" class="select-field" name="codecSelect" autocomplete="off" style="display:none">
            <option value="">Choose codec / bitrate...</option>
          </select>
          <button id="addCameraProfile" class="btn-primary btn-full" type="button" style="display:none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add to Comparison
          </button>
        </div>

        <div id="manualMode" style="display:none" class="stack-sm" role="tabpanel" aria-labelledby="modeManualBtn">
          <div>
            <label class="field-label" for="manualName">Profile Name</label>
            <input id="manualName" name="manualName" type="text" class="input-field" placeholder="Example: ProRes 422 HQ" autocomplete="off" aria-describedby="manualProfileHelp" />
          </div>
          <div>
            <label class="field-label" for="manualBitrate">Bitrate (Mbps)</label>
            <div class="manual-entry-row">
              <input id="manualBitrate" name="manualBitrate" type="number" class="input-field" value="100" min="1" step="0.1" inputmode="decimal" aria-describedby="manualProfileHelp manualValidation" />
              <button id="addManualProfile" class="btn-primary" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Profile
              </button>
            </div>
          </div>
          <div class="chip-row" aria-label="Quick bitrate presets">
            <button class="chip-btn active" type="button" data-bitrate-chip="45">45 Mbps</button>
            <button class="chip-btn" type="button" data-bitrate-chip="50">50 Mbps</button>
            <button class="chip-btn" type="button" data-bitrate-chip="100">100 Mbps</button>
          </div>
          <p id="manualProfileHelp" class="helper-text">Leave the name blank to auto-label it. Rows stay editable after you add them, so you can tune names and bitrates in place.</p>
          <p id="manualValidation" class="helper-text validation-message" aria-live="polite"></p>
        </div>
      </section>

      <!-- Profiles -->
      <section id="comparisonSection" class="card" style="display:none">
        <div class="section-header">
          <div>
            <span class="section-label">File Size Comparison <span id="profileCount" class="inline-count">0</span></span>
            <p id="comparisonHint" class="helper-text helper-tight">The first row acts as the baseline for size delta.</p>
          </div>
          <button id="clearAll" class="clear-btn" type="button">Clear all</button>
        </div>
        <div class="table-scroll profile-table-scroll">
          <table class="data-table profile-table">
            <caption class="sr-only">Recorded profile comparison table</caption>
            <thead>
              <tr>
                <th scope="col">Profile</th>
                <th scope="col">Bitrate</th>
                <th scope="col">Est. Size</th>
                <th scope="col">Delta vs 1st</th>
                <th scope="col">Media Cost</th>
                <th scope="col">Actions</th>
              </tr>
            </thead>
            <tbody id="profilesContainer">
              <tr class="sr-only">
                <td colspan="6">No profiles added yet.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p id="profilesEmpty" class="helper-text empty-state">No profiles yet. Add a camera preset or manual bitrate to compare file size, upload time, and storage yield.</p>
      </section>

      <!-- Bar Chart -->
      <section id="chartSection" class="card" style="display:none">
        <div class="section-header section-header-tight">
          <span class="section-label">Size Comparison</span>
          <span class="section-kicker">Visual size spread</span>
        </div>
        <p class="helper-text section-intro">Bars scale relative to the largest file size in your current comparison.</p>
        <div id="barChart" style="margin-top:8px"></div>
      </section>

      <!-- Settings -->
      <section class="card">
        <div class="section-header section-header-tight">
          <span class="section-label">Planning Assumptions</span>
          <span class="section-kicker">Storage and transfer</span>
        </div>
        <p class="helper-text section-intro">Adjust these assumptions to estimate media cost per profile and total recording time per drive.</p>
        <div class="settings-grid">
          <div>
            <label class="field-label" for="availableStorage">Available Storage (GB)</label>
            <input id="availableStorage" name="availableStorage" type="number" class="input-field" value="500" min="0" step="1" inputmode="numeric" />
          </div>
          <div>
            <label class="field-label" for="costPerTB">Media Cost ($/TB)</label>
            <input id="costPerTB" name="costPerTB" type="number" class="input-field" value="20" min="0" step="0.01" inputmode="decimal" />
          </div>
          <div>
            <label class="field-label" for="customSpeed">Custom Upload Speed (Mbps)</label>
            <input id="customSpeed" name="customSpeed" type="number" class="input-field" value="50" min="1" step="1" inputmode="numeric" />
          </div>
        </div>
        <p id="settingsStatus" class="helper-text">Costs assume decimal TB and transfer speeds in megabits per second.</p>
      </section>

      <!-- Upload Estimates -->
      <section id="uploadSection" class="card" style="display:none">
        <div class="section-header section-header-tight">
          <span class="section-label">Upload Estimates</span>
          <span class="section-kicker">Based on full file size</span>
        </div>
        <p class="helper-text section-intro">Use this to spot whether dailies, proxies, or mezzanine files can move in your available window.</p>
        <div class="table-scroll">
          <table class="data-table">
            <caption class="sr-only">Upload estimate table</caption>
            <thead>
              <tr>
                <th scope="col">Profile</th>
                <th scope="col">Size</th>
                <th scope="col">20M</th>
                <th scope="col">100M</th>
                <th scope="col">1G</th>
                <th scope="col">10G</th>
                <th scope="col" id="customSpeedHeader">50M</th>
              </tr>
            </thead>
            <tbody id="uploadTable">
              <tr class="sr-only">
                <td colspan="7">Add profiles to see upload estimates.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Storage Yield -->
      <section id="yieldSection" class="card" style="display:none">
        <div class="section-header">
          <div>
            <span class="section-label">Storage Yield</span>
            <p class="helper-text helper-tight">Estimated total record time each profile gets from the storage value above.</p>
          </div>
          <span class="yield-badge" id="yieldStorageLabel">500 GB</span>
        </div>
        <div id="capacityResults" class="capacity-list"></div>
      </section>

    </main>

    <footer class="site-footer">
      Bitrate Compare &bull; 2025
    </footer>

    <div id="toast" class="toast" aria-live="polite">Link copied to clipboard</div>
  </div>

  <script type="module" src={appScriptUrl}></script>
</Layout>
