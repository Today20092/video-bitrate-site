---
import '../styles/globals.css';

interface Props {
  title: string;
  description?: string;
}

const { title } = Astro.props;
const description = Astro.props.description ?? 'Compare video bitrates, file sizes, storage yield, and upload time with a fast static calculator.';
const siteUrl = Astro.site ?? Astro.url;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(`${baseUrl}og-image.svg`, siteUrl).toString();
const faviconHref = `${baseUrl}favicon.svg`;
const manifestHref = `${baseUrl}manifest.json`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <link rel="manifest" href={manifestHref} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet" />

    <script is:inline>
      const savedTheme = localStorage.getItem('vbc-theme');
      const preferredTheme = savedTheme || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      if (preferredTheme === 'light') {
        document.documentElement.classList.add('light-theme');
      }
    </script>

    <script is:inline define:vars={{ base: baseUrl }}>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register(`${base}sw.js`, {
          scope: base,
          updateViaCache: 'none',
        });
      }
    </script>
  </head>
  <body class="min-h-screen bg-zinc-950 font-sans text-zinc-100 antialiased transition-colors duration-200 selection:bg-indigo-500 selection:text-white light:bg-zinc-50 light:text-zinc-900">
    <a
      class="absolute top-4 left-4 z-[1000] -translate-y-[220%] rounded-full bg-zinc-900 px-4 py-3 text-sm font-medium text-white shadow-[0_12px_32px_rgba(0,0,0,0.28)] transition-transform duration-200 focus-visible:translate-y-0 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400 light:bg-white light:text-zinc-900"
      href="#main-content"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
